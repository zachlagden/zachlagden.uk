# ======================
# Required Variables
# ======================

# MongoDB connection string
MONGODB_URI=

# Auth.js secret — generate with: openssl rand -base64 32
AUTH_SECRET=

# GitHub OAuth App credentials (for admin login)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# GitHub username that should have admin access
ADMIN_GITHUB_USERNAME=

# ======================
# Optional Variables
# ======================

# Google Analytics measurement ID
NEXT_PUBLIC_GA_ID=

# Discord user ID for presence status widget
NEXT_PUBLIC_DISCORD_USER_ID=
