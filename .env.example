# ======================
# Required Variables
# ======================

# MongoDB connection string
MONGODB_URI=

# Auth.js secret — generate with: openssl rand -base64 32
AUTH_SECRET=

# GitHub OAuth App credentials (for admin login)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# GitHub username that should have admin access
ADMIN_GITHUB_USERNAME=

# ======================
# Optional Variables
# ======================

# GitHub fine-grained PAT for /stats page (Phase 7+)
# Scope: "No repository access" + "Profile: Read-only", expiry ≤ 1 year
# Provisioning runbook: .planning/runbooks/ENV-VARS.md (and PITFALLS.md Pitfall 7)
GITHUB_PAT=
