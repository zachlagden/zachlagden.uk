# ======================
# Required Variables
# ======================

# MongoDB connection string
MONGODB_URI=

# Auth.js secret — generate with: openssl rand -base64 32
AUTH_SECRET=

# GitHub OAuth App credentials (for admin login)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# GitHub username that should have admin access
ADMIN_GITHUB_USERNAME=

# Auth.js v5 requires this when running behind a reverse proxy (Cloudflare,
# Traefik, etc.). Without it next-auth returns "UntrustedHost" on every
# request that touches /api/auth/*. Required in prod; harmless in dev.
# See: https://authjs.dev/getting-started/deployment#auth_trust_host
AUTH_TRUST_HOST=true

# Canonical site URL used by Auth.js to construct OAuth redirect URIs.
# Without it, next-auth derives the redirect_uri from the inbound request
# URL — which inside a Docker container is `http://0.0.0.0:3000`, which
# GitHub rejects. Set this to the public URL in prod; localhost in dev.
# See: https://authjs.dev/getting-started/deployment#auth_url
AUTH_URL=http://localhost:3000

# ======================
# Optional Variables
# ======================

# GitHub fine-grained PAT for /stats page (Phase 7+)
# Scope: "No repository access" + "Profile: Read-only", expiry ≤ 1 year
# Provisioning runbook: .planning/runbooks/ENV-VARS.md (and PITFALLS.md Pitfall 7)
GITHUB_PAT=
